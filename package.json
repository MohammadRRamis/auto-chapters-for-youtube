{
  "name": "auto-chapters-for-youtube",
  "displayName": "Auto Chapters for YouTube",
  "version": "0.0.2",
  "description": "Generate YouTube timestamps and fallback chapters with Gemini, without API keys, on videos without native chapters.",
  "author": "MohammadRRamis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MohammadRRamis/auto-chapters-for-youtube.git"
  },
  "bugs": {
    "url": "https://github.com/MohammadRRamis/auto-chapters-for-youtube/issues"
  },
  "homepage": "https://github.com/MohammadRRamis/auto-chapters-for-youtube#readme",
  "keywords": [
    "plasmo",
    "browser-extension",
    "chrome-extension",
    "youtube",
    "gemini",
    "chapters",
    "timestamps",
    "no-api-key",
    "free-ai"
  ],
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "browser_specific_settings": {
      "gecko": {
        "data_collection_permissions": {
          "required": [
            "none"
          ]
        }
      }
    },
    "permissions": [
      "storage"
    ]
  }
}
